<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="OasisAvatarView">
        <attr name="oasisAvatarType" format="enum">
            <enum name="initial" value="0" />
            <enum name="icon" value="1" />
            <enum name="picture" value="2" />
        </attr>
        <attr name="oasisAvatarSize" format="enum">
            <enum name="size_64" value="0" />
            <enum name="size_96" value="1" />
            <enum name="size_128" value="2" />
        </attr>
        <attr name="oasisInitialText" format="string" />
        <attr name="oasisPictureSrc" format="reference" />
    </declare-styleable>
</resources>