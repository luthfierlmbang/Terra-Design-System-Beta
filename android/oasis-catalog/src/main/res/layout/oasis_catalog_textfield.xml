<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TextField Component"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <com.oasis.designsystem.textfield.OasisTextField
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:oasisTextFieldHint="Username"
            app:oasisTextFieldHelper="Enter your username"
            android:layout_marginBottom="16dp" />

        <com.oasis.designsystem.textfield.OasisTextField
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:oasisTextFieldHint="Password"
            app:oasisTextFieldPassword="true"
            android:layout_marginBottom="16dp" />

        <com.oasis.designsystem.textfield.OasisTextField
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:oasisTextFieldHint="Email"
            app:oasisTextFieldError="Invalid email format"
            app:oasisTextFieldText="not-an-email"
            android:layout_marginBottom="16dp" />

        <com.oasis.designsystem.textfield.OasisTextField
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:oasisTextFieldHint="Description"
            app:oasisTextFieldMultiline="true" />

    </LinearLayout>

</ScrollView>
