<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alert Component"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <com.oasis.designsystem.alert.OasisAlertView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:oasisAlertVariant="info"
            app:oasisAlertTitle="Information"
            app:oasisAlertMessage="This is an informational alert."
            android:layout_marginBottom="12dp" />

        <com.oasis.designsystem.alert.OasisAlertView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:oasisAlertVariant="success"
            app:oasisAlertTitle="Success"
            app:oasisAlertMessage="Your action completed successfully."
            android:layout_marginBottom="12dp" />

        <com.oasis.designsystem.alert.OasisAlertView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:oasisAlertVariant="warning"
            app:oasisAlertTitle="Warning"
            app:oasisAlertMessage="Please review your input before continuing."
            android:layout_marginBottom="12dp" />

        <com.oasis.designsystem.alert.OasisAlertView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:oasisAlertVariant="danger"
            app:oasisAlertTitle="Error"
            app:oasisAlertMessage="Something went wrong. Try again later." />

    </LinearLayout>

</ScrollView>
