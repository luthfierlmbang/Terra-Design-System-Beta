<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tag Component"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- INFO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="INFO"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <com.oasis.designsystem.tag.OasisTagView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:oasisTagVariant="info"
            app:oasisTagText="Information"
            android:layout_marginBottom="16dp" />

        <!-- SUCCESS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SUCCESS"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <com.oasis.designsystem.tag.OasisTagView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:oasisTagVariant="success"
            app:oasisTagText="Success"
            android:layout_marginBottom="16dp" />

        <!-- WARNING -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WARNING"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <com.oasis.designsystem.tag.OasisTagView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:oasisTagVariant="warning"
            app:oasisTagText="Warning"
            android:layout_marginBottom="16dp" />

        <!-- DANGER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DANGER"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <com.oasis.designsystem.tag.OasisTagView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:oasisTagVariant="danger"
            app:oasisTagText="Danger"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</ScrollView>
