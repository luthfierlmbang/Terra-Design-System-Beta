<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Toggle Component"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <com.oasis.designsystem.toggle.OasisToggleView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:oasisToggleLabel="Toggle Off"
            app:oasisToggleChecked="false"
            android:layout_marginBottom="12dp" />

        <com.oasis.designsystem.toggle.OasisToggleView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:oasisToggleLabel="Toggle On"
            app:oasisToggleChecked="true"
            android:layout_marginBottom="12dp" />

        <com.oasis.designsystem.toggle.OasisToggleView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:oasisToggleLabel="Disabled Off"
            app:oasisToggleChecked="false"
            android:enabled="false"
            android:layout_marginBottom="12dp" />

        <com.oasis.designsystem.toggle.OasisToggleView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:oasisToggleLabel="Disabled On"
            app:oasisToggleChecked="true"
            android:enabled="false" />

    </LinearLayout>

</ScrollView>
