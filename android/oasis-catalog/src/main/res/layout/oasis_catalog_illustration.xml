            android:text="connection_problem" android:textAppearance="@style/TextAppearance.Oasis.Label" />

        <com.oasis.designsystem.illustration.OasisIllustrationView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="fitCenter"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            app:oasisIllustrationVariant="3" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="failure_1" android:textAppearance="@style/TextAppearance.Oasis.Label" />

        <com.oasis.designsystem.illustration.OasisIllustrationView
