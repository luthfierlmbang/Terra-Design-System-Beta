<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Avatar Component"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- INITIAL Type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Type: INITIAL"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <com.oasis.designsystem.avatar.OasisAvatarView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisAvatarType="initial"
                app:oasisAvatarSize="size_64"
                android:layout_marginEnd="16dp" />

            <com.oasis.designsystem.avatar.OasisAvatarView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisAvatarType="initial"
                app:oasisAvatarSize="size_96"
                android:layout_marginEnd="16dp" />

            <com.oasis.designsystem.avatar.OasisAvatarView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisAvatarType="initial"
                app:oasisAvatarSize="size_128" />

        </LinearLayout>

        <!-- ICON Type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Type: ICON"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <com.oasis.designsystem.avatar.OasisAvatarView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisAvatarType="icon"
                app:oasisAvatarSize="size_64"
                android:layout_marginEnd="16dp" />

            <com.oasis.designsystem.avatar.OasisAvatarView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisAvatarType="icon"
                app:oasisAvatarSize="size_96"
                android:layout_marginEnd="16dp" />

            <com.oasis.designsystem.avatar.OasisAvatarView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisAvatarType="icon"
                app:oasisAvatarSize="size_128" />

        </LinearLayout>

        <!-- PICTURE Type -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Type: PICTURE"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <com.oasis.designsystem.avatar.OasisAvatarView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisAvatarType="picture"
                app:oasisAvatarSize="size_64"
                android:layout_marginEnd="16dp" />

            <com.oasis.designsystem.avatar.OasisAvatarView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisAvatarType="picture"
                app:oasisAvatarSize="size_96"
                android:layout_marginEnd="16dp" />

            <com.oasis.designsystem.avatar.OasisAvatarView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisAvatarType="picture"
                app:oasisAvatarSize="size_128" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
