<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modal Component"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <com.oasis.designsystem.modal.OasisModalView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:oasisModalTitle="Confirm action"
            app:oasisModalMessage="Are you sure you want to continue?"
            app:oasisModalPrimaryText="Yes, continue"
            app:oasisModalSecondaryText="Cancel" />

    </LinearLayout>

</ScrollView>
