<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RadioButton Component"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <RadioGroup
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.oasis.designsystem.radio.OasisRadioButtonView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisRadioLabel="Option 1"
                app:oasisRadioChecked="true"
                android:layout_marginBottom="12dp" />

            <com.oasis.designsystem.radio.OasisRadioButtonView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisRadioLabel="Option 2"
                app:oasisRadioChecked="false"
                android:layout_marginBottom="12dp" />

            <com.oasis.designsystem.radio.OasisRadioButtonView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisRadioLabel="Option 3"
                app:oasisRadioChecked="false"
                android:layout_marginBottom="12dp" />

        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Disabled State"
            android:textSize="16sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp" />

        <com.oasis.designsystem.radio.OasisRadioButtonView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:oasisRadioLabel="Disabled"
            app:oasisRadioChecked="false"
            android:enabled="false" />

    </LinearLayout>

</ScrollView>
