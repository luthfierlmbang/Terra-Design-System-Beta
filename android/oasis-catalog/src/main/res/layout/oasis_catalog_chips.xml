<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chips Component"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filter Chips"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <com.oasis.designsystem.chip.OasisChip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisChipLabel="All" />

            <com.oasis.designsystem.chip.OasisChip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisChipLabel="Active"
                app:oasisChipSelected="true" />

            <com.oasis.designsystem.chip.OasisChip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisChipLabel="Inactive" />

        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Closable Chips"
            android:textSize="16sp"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.oasis.designsystem.chip.OasisChip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisChipLabel="Design"
                app:oasisChipClosable="true" />

            <com.oasis.designsystem.chip.OasisChip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisChipLabel="Mobile"
                app:oasisChipClosable="true" />

            <com.oasis.designsystem.chip.OasisChip
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:oasisChipLabel="Android"
                app:oasisChipClosable="true" />

        </com.google.android.material.chip.ChipGroup>

    </LinearLayout>

</ScrollView>
