<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="TerraTimerView">
        <attr name="terraTimerLabel" format="string" />
        <attr name="terraTimerValue" format="string" />
        <attr name="terraTimerActive" format="boolean" />
    </declare-styleable>

    <declare-styleable name="TerraLoadingView">
        <attr name="terraLoadingProgress" format="integer" />
        <attr name="terraLoadingMessage" format="string" />
        <attr name="terraLoadingInline" format="boolean" />
    </declare-styleable>

    <declare-styleable name="TerraPageControlView">
        <attr name="terraPageCount" format="integer" />
        <attr name="terraSelectedPage" format="integer" />
    </declare-styleable>

    <declare-styleable name="TerraProgressBarView">
        <attr name="terraProgressBarType" format="enum">
            <enum name="base" value="0" />
            <enum name="bar1" value="1" />
            <enum name="bar2" value="2" />
        </attr>
    </declare-styleable>

    <declare-styleable name="TerraStepperView">
        <attr name="terraStepperCount" format="integer" />
        <attr name="terraStepperCurrentStep" format="integer" />
        <attr name="terraStepperErrorStep" format="integer" />
    </declare-styleable>

    <declare-styleable name="TerraTickerView">
        <attr name="terraTickerTone" format="enum">
            <enum name="information" value="0" />
            <enum name="warning" value="1" />
            <enum name="error" value="2" />
        </attr>
        <attr name="terraTickerDetailed" format="boolean" />
        <attr name="terraTickerTitle" format="string" />
        <attr name="terraTickerMessage" format="string" />
    </declare-styleable>

    <declare-styleable name="TerraEmptyStateView">
        <attr name="terraEmptyStateVariant" format="enum">
            <enum name="searchNotFound" value="0" />
            <enum name="happyBirthday" value="1" />
            <enum name="connectionError" value="2" />
            <enum name="underMaintenance" value="3" />
            <enum name="defaultSearchState" value="4" />
            <enum name="pageNotFound" value="5" />
            <enum name="serverBusy" value="6" />
            <enum name="dataNotFound" value="7" />
            <enum name="timeOut" value="8" />
            <enum name="successSubmit" value="9" />
        </attr>
        <attr name="terraEmptyStateButtonVisible" format="boolean" />
    </declare-styleable>
</resources>
