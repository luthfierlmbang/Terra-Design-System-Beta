<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget" />
    <style name="Widget.Terra" />


    <style name="Widget.Terra.Button" parent="Widget.AppCompat.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:paddingStart">@dimen/terra_spacing_16</item>
        <item name="android:paddingEnd">@dimen/terra_spacing_16</item>
        <item name="android:textColor">@color/terra_color_text_on_primary</item>
    </style>

    <style name="Widget.Terra.Button.Primary" parent="Widget.Terra.Button">
        <item name="android:background">@drawable/terra_bg_button_primary</item>
        <item name="android:textColor">@color/terra_color_text_on_primary</item>
    </style>

    <style name="Widget.Terra.Button.Secondary" parent="Widget.Terra.Button">
        <item name="android:background">@drawable/terra_bg_button_secondary</item>
        <item name="android:textColor">@color/terra_color_text_on_primary</item>
    </style>

    <style name="Widget.Terra.Button.OutlinedPrimary" parent="Widget.Terra.Button">
        <item name="android:background">@drawable/terra_bg_button_outlined_primary</item>
        <item name="android:textColor">@color/terra_color_primary</item>
    </style>

    <style name="Widget.Terra.Button.OutlinedSecondary" parent="Widget.Terra.Button">
        <item name="android:background">@drawable/terra_bg_button_outlined_secondary</item>
        <item name="android:textColor">@color/terra_color_secondary</item>
    </style>

    <style name="Widget.Terra.Button.Danger" parent="Widget.Terra.Button">
        <item name="android:background">@drawable/terra_bg_button_danger</item>
        <item name="android:textColor">@color/terra_color_text_on_primary</item>
    </style>

    <style name="Widget.Terra.Button.Text" parent="Widget.Terra.Button">
        <item name="android:background">@color/terra_color_transparent</item>
        <item name="android:textColor">@color/terra_color_primary</item>
    </style>
</resources>
