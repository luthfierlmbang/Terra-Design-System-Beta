<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="TerraChipView">
        <attr name="terraChipText" format="string" />
        <attr name="terraChipSelected" format="boolean" />
        <attr name="terraChipShowLeftIcon" format="boolean" />
        <attr name="terraChipShowRightIcon" format="boolean" />
        <attr name="terraChipShowCounter" format="boolean" />
        <attr name="terraChipCounterValue" format="integer" />
    </declare-styleable>

    <declare-styleable name="TerraNavbarView">
        <attr name="terraNavbarSelectedItem" format="enum">
            <enum name="home" value="0" />
            <enum name="activity" value="1" />
            <enum name="notification" value="2" />
            <enum name="none" value="3" />
        </attr>
    </declare-styleable>

    <declare-styleable name="TerraCheckboxView">
        <attr name="terraSelectionLabel" format="string" />
        <attr name="terraSelectionChecked" format="boolean" />
        <attr name="terraSelectionEnabled" format="boolean" />
    </declare-styleable>

    <declare-styleable name="TerraRadioView">
        <attr name="terraSelectionLabel" format="string" />
        <attr name="terraSelectionChecked" format="boolean" />
        <attr name="terraSelectionEnabled" format="boolean" />
    </declare-styleable>

    <declare-styleable name="TerraToggleView">
        <attr name="terraSelectionLabel" format="string" />
        <attr name="terraSelectionChecked" format="boolean" />
        <attr name="terraSelectionEnabled" format="boolean" />
    </declare-styleable>

    <declare-styleable name="TerraTabView">
        <attr name="terraTabItems" format="string" />
        <attr name="terraTabSelectedIndex" format="integer" />
        <attr name="terraTabScrollable" format="boolean" />
    </declare-styleable>
</resources>
