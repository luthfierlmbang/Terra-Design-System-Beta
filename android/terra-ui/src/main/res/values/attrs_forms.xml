<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="TerraImageUploadView">
        <attr name="terraImageUploadLabel" format="string" />
        <attr name="terraImageUploadHint" format="string" />
        <attr name="terraImageUploadState" format="enum">
            <enum name="upload" value="0" />
            <enum name="processing" value="1" />
            <enum name="attachedOneCta" value="2" />
            <enum name="attachedTwoCta" value="3" />
        </attr>
    </declare-styleable>

    <declare-styleable name="TerraBottomSheetView">
        <attr name="terraBottomSheetTitle" format="string" />
        <attr name="terraBottomSheetVariant" format="enum">
            <enum name="options" value="0" />
            <enum name="countdown" value="1" />
        </attr>
        <attr name="terraBottomSheetSearchEnabled" format="boolean" />
        <attr name="terraBottomSheetExpanded" format="boolean" />
    </declare-styleable>

    <declare-styleable name="TerraDatePickerView">
        <attr name="terraDatePickerMode" format="enum">
            <enum name="single" value="0" />
            <enum name="double" value="1" />
        </attr>
        <attr name="terraDatePickerMonth" format="string" />
        <attr name="terraDatePickerNextMonth" format="string" />
        <attr name="terraDatePickerYear" format="string" />
    </declare-styleable>

    <declare-styleable name="TerraSearchBarView">
        <attr name="terraSearchBarText" format="string" />
        <attr name="terraSearchBarState" format="enum">
            <enum name="default" value="0" />
            <enum name="focus" value="1" />
            <enum name="result" value="2" />
            <enum name="disabled" value="3" />
        </attr>
    </declare-styleable>

    <declare-styleable name="TerraSelectView">
        <attr name="terraSelectPlaceholder" format="string" />
        <attr name="terraSelectFilled" format="boolean" />
        <attr name="terraSelectSearchEnabled" format="boolean" />
        <attr name="terraSelectSearchFocused" format="boolean" />
    </declare-styleable>

    <declare-styleable name="TerraTextFieldView">
        <attr name="terraTextFieldLabel" format="string" />
        <attr name="terraTextFieldPlaceholder" format="string" />
        <attr name="terraTextFieldHelper" format="string" />
        <attr name="terraTextFieldVariant" format="enum">
            <enum name="default" value="0" />
            <enum name="textPrefix" value="1" />
            <enum name="textPrefixIcon" value="2" />
            <enum name="textSuffix" value="3" />
        </attr>
        <attr name="terraTextFieldShowLabel" format="boolean" />
        <attr name="terraTextFieldShowHelper" format="boolean" />
        <attr name="terraTextFieldShowLeftIcon" format="boolean" />
        <attr name="terraTextFieldShowRightIcon" format="boolean" />
    </declare-styleable>

    <declare-styleable name="TerraQuantityEditorView">
        <attr name="terraQuantityValue" format="string" />
        <attr name="terraQuantityState" format="enum">
            <enum name="default" value="0" />
            <enum name="minimum" value="1" />
            <enum name="maximum" value="2" />
        </attr>
    </declare-styleable>
</resources>
